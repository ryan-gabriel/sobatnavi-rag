# ============================================================
# SobatNavi AI Agent — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.
# ============================================================

# ── OpenAI ─────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL_ID=gpt-4.1-nano
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Supabase (required) ─────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# ── Third-party APIs (optional — features degrade gracefully) ─
TOMTOM_API_KEY=
TAVILY_API_KEY=
OPENWEATHERMAP_API_KEY=

# ── App ──────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Security: CORS ───────────────────────────────────────────
# Comma-separated list of allowed origins.
# Use "*" in development, explicit origins in production.
# Example (production): https://app.sobatnavi.com,https://admin.sobatnavi.com
ALLOWED_ORIGINS=*

# ── Security: Trusted Hosts ──────────────────────────────────
# Comma-separated list of allowed Host header values.
# Use "*" in development, explicit hostnames in production.
# Example (production): sobatnavi.com,api.sobatnavi.com
ALLOWED_HOSTS=*

# ── Security: Rate Limiting ──────────────────────────────────
# Set to "false" to disable rate limiting during local development or tests.
RATE_LIMIT_ENABLED=true
